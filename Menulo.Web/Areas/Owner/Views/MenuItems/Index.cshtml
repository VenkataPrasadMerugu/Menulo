@model Menulo.Web.ViewModels.Owner.MenuItemListViewModel
@using Menulo.Domain.Modules.Menu
@{
    ViewData["Title"] = "Menu Items";
}

<div class="owner-shell">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <span class="eyebrow">Menu Module</span>
            <h1 class="h2 mt-2">Menu items</h1>
            <p class="text-muted mb-0">Choose category and veg or non-veg while adding items. Only <strong>Active</strong> and <strong>OutOfStock</strong> items appear on the public menu.</p>
        </div>
        <a class="btn btn-brand" asp-action="Create" asp-route-restaurantId="@Model.RestaurantId">Add menu item</a>
    </div>

    @if (Model.Restaurants.Count > 0)
    {
        <div class="panel-card mb-4">
            <div class="restaurant-switcher">
                @foreach (var restaurant in Model.Restaurants)
                {
                    <a class="restaurant-chip @(Model.RestaurantId == restaurant.Id ? "active" : string.Empty)" asp-area="Owner" asp-controller="Dashboard" asp-action="SelectRestaurant" asp-route-restaurantId="@restaurant.Id" asp-route-returnUrl="@Url.Action("Index", "MenuItems", new { area = "Owner" })">
                        <strong>@restaurant.Name</strong>
                        <span>@(restaurant.BranchName ?? restaurant.PublicMenuPath)</span>
                    </a>
                }
            </div>
        </div>
    }

    <div class="panel-card mb-4">
        <div class="d-flex flex-column gap-3">
            <div>
                <h2 class="h5 mb-1">Import items from another restaurant</h2>
                <p class="text-muted mb-0">Select a source restaurant, then choose only the items you want to copy into the current restaurant.</p>
            </div>
            <form method="get" asp-action="Index" class="d-flex flex-column flex-sm-row gap-2 align-items-stretch">
                <input type="hidden" name="restaurantId" value="@Model.RestaurantId" />
                <select name="importSourceRestaurantId" class="form-select" @(Model.ImportSources.Count == 0 ? "disabled" : null)>
                    <option value="">Select source restaurant</option>
                    @foreach (var source in Model.ImportSources)
                    {
                        <option value="@source.Id" selected="@(Model.ImportSourceRestaurantId == source.Id ? "selected" : null)">@source.Name @(string.IsNullOrWhiteSpace(source.BranchName) ? string.Empty : $"- {source.BranchName}")</option>
                    }
                </select>
                <button type="submit" class="btn btn-outline-dark" @(Model.ImportSources.Count == 0 ? "disabled" : null)>Load items</button>
            </form>

            @if (Model.ImportSourceRestaurantId.HasValue)
            {
                <form method="post" asp-action="Import">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="restaurantId" value="@Model.RestaurantId" />
                    <input type="hidden" name="importSourceRestaurantId" value="@Model.ImportSourceRestaurantId" />

                    @if (Model.ImportableItems.Count == 0)
                    {
                        <p class="mb-0 text-muted">No items found in the selected source restaurant.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th style="width:48px;">
                                            <input type="checkbox" class="form-check-input" data-check-all="import-items" />
                                        </th>
                                        <th>Image</th>
                                        <th>Item</th>
                                        <th>Type</th>
                                        <th>Category</th>
                                        <th>Price</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.ImportableItems)
                                    {
                                        <tr>
                                            <td>
                                                <input type="checkbox" class="form-check-input" name="selectedMenuItemIds" value="@item.Id" data-check-group="import-items" />
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(item.PrimaryImagePath))
                                                {
                                                    <img src="@Url.Content(item.PrimaryImagePath)" class="table-item-image" alt="@item.Name" />
                                                }
                                            </td>
                                            <td>@item.Name</td>
                                            <td>
                                                <span class="food-type-pill @(item.FoodType == "Veg" ? "veg" : "non-veg")">@item.FoodType</span>
                                            </td>
                                            <td>@item.Category</td>
                                            <td>@item.Price.ToString("0.00")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-outline-dark">Import selected items</button>
                        </div>
                    }
                </form>
            }
        </div>
    </div>

    <div class="panel-card">
        @if (Model.Items.Count == 0)
        {
            <p class="mb-0 text-muted">No items yet. Add your first menu item to start publishing the menu.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Item name</th>
                            <th>Type</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.PrimaryImagePath))
                                    {
                                        <img src="@Url.Content(item.PrimaryImagePath)" class="table-item-image" alt="@item.Name" />
                                    }
                                </td>
                                <td>@item.Name</td>
                                <td>
                                    <span class="food-type-pill @(item.FoodType == FoodType.Veg ? "veg" : "non-veg")">@item.FoodType</span>
                                </td>
                                <td>@item.Category</td>
                                <td>@item.ImagePaths.Count image(s)<br />@item.Price.ToString("0.00")</td>
                                <td><span class="badge rounded-pill text-bg-light border">@item.Status</span></td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@item.Id" asp-route-restaurantId="@Model.RestaurantId">Edit</a>
                                        <form method="post" asp-action="Delete" asp-route-id="@item.Id">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="restaurantId" value="@Model.RestaurantId" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                        </form>
                                        <form method="post" asp-action="SetStatus" asp-route-id="@item.Id">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="restaurantId" value="@Model.RestaurantId" />
                                            <input type="hidden" name="status" value="@MenuItemStatus.Active" />
                                            <button class="btn btn-sm btn-outline-success" type="submit">Activate</button>
                                        </form>
                                        <form method="post" asp-action="SetStatus" asp-route-id="@item.Id">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="restaurantId" value="@Model.RestaurantId" />
                                            <input type="hidden" name="status" value="@MenuItemStatus.Inactive" />
                                            <button class="btn btn-sm btn-outline-secondary" type="submit">Deactivate</button>
                                        </form>
                                        <form method="post" asp-action="SetStatus" asp-route-id="@item.Id">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="restaurantId" value="@Model.RestaurantId" />
                                            <input type="hidden" name="status" value="@MenuItemStatus.OutOfStock" />
                                            <button class="btn btn-sm btn-outline-warning" type="submit">Out of stock</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
