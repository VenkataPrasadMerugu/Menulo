@{
    ViewData["Title"] = "Menulo";
}

<section class="landing-shell">
    <div class="container py-5">
        <div class="landing-hero">
            <div class="landing-copy">
                <span class="landing-badge">Restaurant Digital Menu Platform</span>
                <h1 class="landing-title">
                    Turn your restaurant menu into a
                    <span>smart digital experience</span>
                </h1>
                <p class="landing-subtitle">
                    Menulo gives restaurant owners one clean place to manage branding, branches, menu items, QR-ready public menus, and mobile-first customer pages.
                </p>

                <div class="landing-actions">
                    <a class="btn btn-brand btn-lg" asp-controller="Account" asp-action="Register">Get started now</a>
                    <a class="btn btn-outline-dark btn-lg" asp-area="Owner" asp-controller="Dashboard" asp-action="Index">Open dashboard</a>
                </div>

                <div class="landing-metrics">
                    <div class="landing-metric">
                        <strong>5 min</strong>
                        <span>to launch one branded menu</span>
                    </div>
                    <div class="landing-metric">
                        <strong>Multi-branch</strong>
                        <span>one owner can manage many restaurants</span>
                    </div>
                    <div class="landing-metric">
                        <strong>QR-ready</strong>
                        <span>share menu links or printable QR codes</span>
                    </div>
                </div>
            </div>

            <div class="landing-visual">
                <div class="landing-phone">
                    <div class="landing-phone-notch"></div>

                    <div class="landing-device">
                        <div class="landing-device-top">
                            <span class="landing-time">9:41</span>
                            <span class="landing-url">menulo.app/vizag-cuisine</span>
                            <span class="landing-pill">Live</span>
                        </div>

                        <div class="landing-device-body">
                            <div class="landing-device-header">
                                <div>
                                    <h2>Vizag Cuisine</h2>
                                    <p>Seethammadhara, Visakhapatnam</p>
                                </div>
                                <div class="landing-rating">
                                    <strong>4.8</strong>
                                    <span>Rating</span>
                                </div>
                            </div>

                            <div class="landing-tags">
                                <span>Seafood</span>
                                <span>Andhra Meals</span>
                                <span>Fast service</span>
                            </div>

                            <div class="landing-preview-list">
                                <article class="landing-preview-item">
                                    <div class="landing-preview-thumb warm"></div>
                                    <div class="landing-preview-content">
                                        <strong>Chicken Biryani</strong>
                                        <p>Serves 2 • Non-Veg • Rice &amp; Biryani</p>
                                    </div>
                                    <span class="landing-price">Rs 320</span>
                                </article>

                                <article class="landing-preview-item">
                                    <div class="landing-preview-thumb green"></div>
                                    <div class="landing-preview-content">
                                        <strong>Royyala Vepudu</strong>
                                        <p>Serves 1 • Seafood • Starters</p>
                                    </div>
                                    <span class="landing-price">Rs 280</span>
                                </article>

                                <article class="landing-preview-item">
                                    <div class="landing-preview-thumb gold"></div>
                                    <div class="landing-preview-content">
                                        <strong>Veg Meals</strong>
                                        <p>Serves 1 • Veg • Main Course</p>
                                    </div>
                                    <span class="landing-price">Rs 180</span>
                                </article>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
