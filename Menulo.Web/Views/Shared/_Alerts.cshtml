@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show app-alert js-auto-alert" role="alert" data-timeout="3500">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show app-alert js-auto-alert" role="alert" data-timeout="5000">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
