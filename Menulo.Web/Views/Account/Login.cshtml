@model Menulo.Web.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Login";
    ViewData["BodyClass"] = "auth-body";
}

<section class="auth-shell">
    <div class="auth-layout">
        <aside class="auth-showcase">
            <div class="auth-showcase-inner">
                <a class="auth-brandmark" asp-controller="Home" asp-action="Index">
                    <span class="auth-brandmark-icon">M</span>
                    <span>Menulo</span>
                </a>

                <div class="auth-showcase-copy">
                    <span class="auth-kicker">Restaurant control center</span>
                    <h1>Run your menu, branding, and branches from one clean workspace.</h1>
                    <p>
                        Menulo helps restaurant owners publish branded menus, manage branches, control item availability, and share QR-ready public links that work well on mobile.
                    </p>
                </div>

                <div class="auth-feature-list">
                    <div class="auth-feature-item">
                        <span class="auth-feature-icon">QR</span>
                        <div>
                            <strong>QR-ready public menus</strong>
                            <p>Share live menu links instantly with customers.</p>
                        </div>
                    </div>
                    <div class="auth-feature-item">
                        <span class="auth-feature-icon">BR</span>
                        <div>
                            <strong>Branch-based management</strong>
                            <p>Keep branding and menu control organized per restaurant.</p>
                        </div>
                    </div>
                    <div class="auth-feature-item">
                        <span class="auth-feature-icon">MO</span>
                        <div>
                            <strong>Mobile-first customer view</strong>
                            <p>Compact, restaurant-style menu screens that feel familiar.</p>
                        </div>
                    </div>
                </div>

                <div class="auth-testimonial">
                    <p>
                        “We moved from static PDFs to a live branded menu and updates now take minutes instead of hours.”
                    </p>
                    <strong>Restaurant owner workflow, simplified.</strong>
                </div>
            </div>
        </aside>

        <div class="auth-panel-wrap">
            <div class="auth-panel auth-panel-narrow">
                <div class="auth-panel-header">
                    <span class="auth-panel-badge">Owner access</span>
                    <h2>Welcome back</h2>
                    <p>Sign in to manage your dashboard, branding, branches, and menu items.</p>
                </div>

                <form method="post" novalidate class="auth-form-grid">
                    <input asp-for="ReturnUrl" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small auth-validation-summary"></div>

                    <div class="auth-field">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control auth-input" placeholder="owner@restaurant.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control auth-input" placeholder="Enter your password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="auth-row-meta">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-brand btn-lg auth-submit">Sign in</button>
                </form>

                <div class="auth-footer-note">
                    <span>Need an account?</span>
                    <a asp-action="Register">Create owner account</a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
